# OpenAI (required for /api/hr and /api/agent)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5

# Auth (required for login)
NEXTAUTH_SECRET=your-random-secret-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000
AUTH_EMAIL=admin@example.com
AUTH_PASSWORD=Alph@123

# Optional: in development, set to "1" to append logs to ./logs/hr-api.log
# LOG_TO_FILE=1

# Optional: on Vercel, suppress Node deprecation warning from dependencies (url.parse)
# NODE_OPTIONS=--disable-warning=DEP0169

# Landing page + free trial (magic link)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
RESEND_API_KEY=re_...
RESEND_FROM=trial@yourdomain.com
# Optional if different from NEXTAUTH_URL (used as base for magic link URL)
# SITE_URL=https://seeknimbly.ai

# Stripe (15-day free trial; cancel anytime via Billing portal)
STRIPE_SECRET_KEY=sk_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
